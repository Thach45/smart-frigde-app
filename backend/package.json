{
  "name": "rewear-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../.env -- tsx watch src/index.ts",
    "build": "dotenv -e ../.env -- tsc",
    "start": "dotenv -e ../.env -- node dist/index.js",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:studio": "dotenv -e ../.env -- prisma studio"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "google-auth-library": "^10.1.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
